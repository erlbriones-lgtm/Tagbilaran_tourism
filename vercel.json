{
  "headers": [
    {
      "source": "/(.*)\\.(css|js|png|jpg|jpeg|webp|svg|gif|ico|mp4|webm|woff2|woff|ttf)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}
